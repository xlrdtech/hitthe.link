{
  "name": "elios-buyer-portal-backend",
  "version": "0.1.0",
  "private": true,
  "description": "EliOS gated buyer portal — Cloudflare Worker (Stripe webhook + checkout/portal + monthly lead-grant allocator) backed by Supabase Auth/Postgres/RLS.",
  "type": "module",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "sync:leads": "node scripts/sync-leads.mjs",
    "sync:leads:asana": "node scripts/sync-leads.mjs --source=asana",
    "allocate:local": "node scripts/run-allocate.mjs",
    "provision:logins": "node scripts/provision-logins.mjs",
    "provision:logins:dry": "node scripts/provision-logins.mjs --dry-run",
    "provision:logins:invite": "node scripts/provision-logins.mjs --mode=invite",
    "provision:logins:magiclink": "node scripts/provision-logins.mjs --mode=magiclink"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}

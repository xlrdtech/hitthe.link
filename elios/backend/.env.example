# =====================================================================
# EliOS Buyer Portal — environment template
# =====================================================================
# Copy to `.env` for local operator scripts (sync-leads / run-allocate) and
# mirror these as Cloudflare Worker SECRETS via `wrangler secret put <NAME>`.
#
# !!! NEVER commit a filled-in .env. Only this .example belongs in the repo. !!!
# The Stripe secret key, webhook secret, OAuth client secret, and the Supabase
# service-role key are LIVE SECRETS — Worker Secrets / local .env only.
# =====================================================================

# ---- Stripe (Billing source of truth) -------------------------------
# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_xxx                 # SECRET (use sk_test_ while staging)
STRIPE_PUBLISHABLE_KEY=pk_live_xxx            # PUBLIC — used by the static /pay + portal page
# Dashboard > Developers > Webhooks > (your endpoint) > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx               # SECRET
# Dashboard > Product catalog > Prices  (two recurring prices)
STRIPE_PRICE_PLAN_A=price_xxx                 # $100/mo -> 30 leads
STRIPE_PRICE_PLAN_B=price_xxx                 # $40/mo  -> 15 leads

# ---- Supabase (Auth + DB + RLS source of truth) ---------------------
# Project Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...                       # PUBLIC (publishable) — for the static portal only
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # SECRET — Worker + operator scripts ONLY (RLS bypass)

# ---- Google OAuth (configured in Supabase Auth, NOT in app code) -----
# Set these in Supabase Dashboard > Authentication > Providers > Google.
# Listed here only as the credential prerequisite checklist.
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com   # goes into Supabase provider config
GOOGLE_OAUTH_CLIENT_SECRET=xxx                            # SECRET — Supabase provider config only
# Authorized redirect URI to register in Google Cloud Console:
#   https://<project-ref>.supabase.co/auth/v1/callback

# ---- Worker operational ---------------------------------------------
CRON_SECRET=replace-with-long-random-string    # protects POST /api/allocate-grants
ALLOWED_ORIGIN=https://tools.trackingtogether.com   # CORS + Checkout/Portal return URLs

# ---- Asana sync (operator script only; optional) --------------------
ASANA_PAT=1/xxxx                               # SECRET — personal access token for Lead Master sync
ASANA_LEAD_MASTER_PROJECT_GID=12000xxxxxxxxxx  # GID of the "Lead Master" project

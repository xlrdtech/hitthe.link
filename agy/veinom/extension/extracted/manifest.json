{
  "manifest_version": 3,
  "name": "AGY VENOM · RUACH",
  "version": "0.8.1",
  "description": "Voice-first wrapper for any web chat. Hear and speak every AI conversation. Dual-pipe to tui.xlrd.org for automanifestation.",
  "author": "XLRD TECH",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://grok.com/*",
    "https://x.com/i/grok*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://chat.mistral.ai/*",
    "https://chat.deepseek.com/*",
    "https://you.com/*",
    "https://copilot.microsoft.com/*",
    "https://huggingface.co/chat/*",
    "https://app.sintra.ai/*",
    "https://sintra.ai/*",
    "https://poe.com/*",
    "https://kagi.com/*",
    "https://character.ai/*",
    "https://chat.lmsys.org/*",
    "https://chat.qwen.ai/*",
    "https://kimi.ai/*",
    "https://meta.ai/*",
    "https://chat.cohere.com/*",
    "https://tui.xlrd.org/*",
    "https://ava.xlrd.org/*",
    "http://localhost:7723/*",
    "http://127.0.0.1:7723/*",
    "https://hitthe.link/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://chat.mistral.ai/*",
        "https://chat.deepseek.com/*",
        "https://you.com/*",
        "https://copilot.microsoft.com/*",
        "https://huggingface.co/chat/*",
        "https://app.sintra.ai/*",
        "https://sintra.ai/*",
        "https://poe.com/*",
        "https://kagi.com/*",
        "https://character.ai/*",
        "https://chat.lmsys.org/*",
        "https://chat.qwen.ai/*",
        "https://kimi.ai/*",
        "https://meta.ai/*",
        "https://chat.cohere.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://hitthe.link/agy/veinom/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "panel.html",
    "default_title": "AGY VENOM voice loop · click to toggle",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.css"],
      "matches": ["<all_urls>"]
    }
  ]
}

{
  "name": "godmode__cloud_storage",
  "description": "[Godmode (Mac shell — run_command + full desktop automation)] Manage cloud storage",
  "inputSchema": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "status",
          "list",
          "upload",
          "organize"
        ],
        "description": "Action"
      },
      "provider": {
        "type": "string",
        "enum": [
          "icloud",
          "googledrive",
          "dropbox",
          "auto"
        ],
        "description": "Cloud provider"
      },
      "path": {
        "type": "string",
        "description": "File/folder path"
      },
      "destination": {
        "type": "string",
        "description": "Target cloud folder"
      },
      "pattern": {
        "type": "string",
        "enum": [
          "by_type",
          "by_date",
          "by_project"
        ],
        "description": "For organize: grouping"
      }
    }
  }
}
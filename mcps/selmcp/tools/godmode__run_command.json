{
  "name": "godmode__run_command",
  "description": "[Godmode (Mac shell — run_command + full desktop automation)] Execute a shell command on the Mac. Returns stdout + stderr.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "command": {
        "type": "string",
        "description": "Shell command to execute"
      },
      "cwd": {
        "type": "string",
        "description": "Working directory (default: user home)"
      },
      "timeout": {
        "type": "number",
        "description": "Timeout in ms (default: 120000)"
      }
    },
    "required": [
      "command"
    ]
  }
}
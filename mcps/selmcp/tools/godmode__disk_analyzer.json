{
  "name": "godmode__disk_analyzer",
  "description": "[Godmode (Mac shell — run_command + full desktop automation)] Analyze disk usage",
  "inputSchema": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "overview",
          "largest",
          "old_files",
          "duplicates"
        ],
        "description": "Analysis type"
      },
      "path": {
        "type": "string",
        "description": "Target path"
      },
      "count": {
        "type": "number",
        "description": "Number of results"
      },
      "days": {
        "type": "number",
        "description": "For old_files: days since last access"
      },
      "min_size_mb": {
        "type": "number",
        "description": "Min file size in MB"
      }
    }
  }
}
{
  "name": "godmode__mouse_click",
  "description": "[Godmode (Mac shell — run_command + full desktop automation)] Move mouse to coordinates and click",
  "inputSchema": {
    "type": "object",
    "properties": {
      "x": {
        "type": "number",
        "description": "X coordinate"
      },
      "y": {
        "type": "number",
        "description": "Y coordinate"
      },
      "button": {
        "type": "string",
        "description": "left, right, or middle (default: left)"
      },
      "double_click": {
        "type": "boolean",
        "description": "Double click"
      }
    },
    "required": [
      "x",
      "y"
    ]
  }
}
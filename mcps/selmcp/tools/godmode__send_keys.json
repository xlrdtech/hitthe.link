{
  "name": "godmode__send_keys",
  "description": "[Godmode (Mac shell — run_command + full desktop automation)] Send keystrokes to the frontmost application. Supports modifiers.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "keys": {
        "type": "string",
        "description": "Text to type, or special key name"
      },
      "app": {
        "type": "string",
        "description": "Optional: target app name"
      },
      "modifiers": {
        "type": "string",
        "description": "Optional: modifiers like 'command down'"
      },
      "key_code": {
        "type": "number",
        "description": "Optional: raw key code number"
      }
    },
    "required": [
      "keys"
    ]
  }
}
{
  "name": "godmode__cpu_manager",
  "description": "[Godmode (Mac shell — run_command + full desktop automation)] CPU management",
  "inputSchema": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "status",
          "top",
          "thermal",
          "power"
        ],
        "description": "Action"
      },
      "count": {
        "type": "number",
        "description": "For top: number of processes"
      },
      "mode": {
        "type": "string",
        "enum": [
          "low",
          "auto",
          "high"
        ],
        "description": "For power: lowpowermode 0/1 or auto"
      }
    }
  }
}
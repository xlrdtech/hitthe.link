{
  "name": "getRepositoryTag",
  "description": "Get the details of a tag in a repository. It can be use to show the latest tag details for example.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "namespace": {
        "type": "string"
      },
      "repository": {
        "type": "string"
      },
      "tag": {
        "type": "string"
      }
    },
    "required": [
      "namespace",
      "repository",
      "tag"
    ],
    "type": "object"
  }
}
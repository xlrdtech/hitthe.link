corners\n  vec3 g_0 = step(x0.yzx, x0.xyz);\n  vec3 l = 1.0 - g_0;\n  vec3 i1 = min( g_0.xyz, l.zxy );\n  vec3 i2 = max( g_0.xyz, l.zxy );\n\n  //   x0 = x0 - 0.0 + 0.0 * C.xxx;\n  //   x1 = x0 - i1  + 1.0 * C.xxx;\n  //   x2 = x0 - i2  + 2.0 * C.xxx;\n  //   x3 = x0 - 1.0 + 3.0 * C.xxx;\n  vec3 x1 = x0 - i1 + C.xxx;\n  vec3 x2 = x0 - i2 + C.yyy; // 2.0*C.x = 1/3 = C.y\n  vec3 x3 = x0 - D.yyy;      // -1.0+3.0*C.x = -0.5 = -D.y\n\n// Permutations\n  i = mod289(i);\n  vec4 p = permute( permute( permute(\n             i.z + vec4(0.0, i1.z, i2.z, 1.0 ))\n           + i.y + vec4(0.0, i1.y, i2.y, 1.0 ))\n           + i.x + vec4(0.0, i1.x, i2.x, 1.0 ));\n\n// Gradients: 7x7 points over a square, mapped onto an octahedron.\n// The ring size 17*17 = 289 is close to a multiple of 49 (49*6 = 294)\n  float n_ = 0.142857142857; // 1.0/7.0\n  vec3  ns = n_ * D.wyz - D.xzx;\n\n  vec4 j = p - 49.0 * floor(p * ns.z * ns.z);  //  mod(p,7*7)\n\n  vec4 x_ = floor(j * ns.z);\n  vec4 y_ = floor(j - 7.0 * x_ );    // mod(j,N)\n\n  vec4 x = x_ *ns.x + ns.yyyy;\n  vec4 y = y_ *ns.x + ns.yyyy;\n  vec4 h = 1.0 - abs(x) - abs(y);\n\n  vec4 b0 = vec4( x.xy, y.xy );\n  vec4 b1 = vec4( x.zw, y.zw );\n\n  //vec4 s0 = vec4(lessThan(b0,0.0))*2.0 - 1.0;\n  //vec4 s1 = vec4(lessThan(b1,0.0))*2.0 - 1.0;\n  vec4 s0 = floor(b0)*2.0 + 1.0;\n  vec4 s1 = floor(b1)*2.0 + 1.0;\n  vec4 sh = -step(h, vec4(0.0));\n\n  vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy ;\n  vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww ;\n\n  vec3 p0 = vec3(a0.xy,h.x);\n  vec3 p1 = vec3(a0.zw,h.y);\n  vec3 p2 = vec3(a1.xy,h.z);\n  vec3 p3 = vec3(a1.zw,h.w);\n\n//Normalise gradients\n  vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2, p2), dot(p3,p3)));\n  p0 *= norm.x;\n  p1 *= norm.y;\n  p2 *= norm.z;\n  p3 *= norm.w;\n\n// Mix final noise value\n  vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);\n  m = m * m;\n  return 42.0 * dot( m*m, vec4( dot(p0,x0), dot(p1,x1),\n                                dot(p2,x2), dot(p3,x3) ) );\n  }\n\nuniform sampler2D tDiffuse;\nuniform sampler2D uAnnotations;\nuniform sampler2D uGrid;\nuniform sampler2D uPaper;\nuniform float uTime;\nuniform vec2 uResolution;\nuniform vec3 uTintColor;\nuniform vec3 uBgColor;\nuniform float uThreshold;\nuniform float uTransition;\nuniform float uInnerRadius;\nuniform float uOuterRadius;\nuniform bool uLoaderTransition;\n\nvarying vec2 vUv;\n\nfloat circle(in vec2 _st, in float _scale, in float _radius, in float _fade){\n    vec2 dist = _st / _scale;\n\treturn 1.-smoothstep(_radius-(_radius*_fade),\n                         _radius+(_radius*_fade),\n                         dot(dist,dist)*4.0);\n}\n\nvoid main() {\n    vec4 sketchColor;\n    vec4 sceneColor = texture2D(tDiffuse, vUv);\n\n\t// simple sobel edge detection\n    float gx = texture2D(tDiffuse, vUv.xy+vec2(uThreshold, 0.)).x\n    - texture2D(tDiffuse, vUv.xy-vec2(uThreshold, 0.)).x ;\n\n    float gy = texture2D(tDiffuse, vUv.xy+vec2(0.,uThreshold)).x\n    - texture2D(tDiffuse, vUv.xy-vec2(0., uThreshold)).x;\n\n\t// hack: use g^2 to conceal noise in the video\n    float g = gx*gx + gy*gy;\n\n    vec4 col = texture2D(tDiffuse, vUv);\n    col = clamp(vec4(1.)-vec4(vec3(g)*100., 1.0),0.9,1.);\n\n    sketchColor = pow(col,vec4(2.5));\n\n    // Tint\n    // To make the sobel edges lighter than the background we invert the both the tint and sketchColor values\n    vec3 tint = vec3(1.0 - uTintColor.r, 1.0 - uTintColor.g, 1.0 - uTintColor.b);\n    sketchColor.rgb *= tint;\n    sketchColor.rgb = vec3(1.0 - sketchColor.r, 1.0 - sketchColor.g, 1.0 - sketchColor.b);\n\n    vec2 gridPaperUv = vec2(vUv.x * (uResolution.x / uResolution.y) * 70.0, vUv.y * 70.0);\n    vec3 gridPaper = texture2D( uGrid, gridPaperUv ).rgb;\n    gridPaper = blendLighten(sketchColor.rgb, gridPaper, .5);\n\n    vec2 paperUv = vec2( vUv.x * uResolution.x / 400., vUv.y * uResolution.y / 400. );\n    vec3 paper = texture2D( uPaper, paperUv ).rgb;\n    sketchColor.rgb = blendLighten(sketchColor.rgb, paper, .5);\n\n    vec2 centered = vUv - vec2(0.5);\n    float sketchVignette = smoothstep(0.0, 0.5, length(centered));\n\n    vec4 annotationsScene = texture2D( uAnnotations, vUv );\n    annotationsScene *= 0.5;\n    annotationsScene *= 1.0 - sketchVignette;\n    sketchColor += annotationsScene;\n\n    float vignette = smoothstep(uInnerRadius, uOuterRadius, length(centered));\n\tsketchColor.rgb = mix(sketchColor.rgb, gridPaper, vignette);\n\n    // Transition\n    float time = uTime * 0.05 + 23.0;\n    float ratio = uResolution.x / uResolution.y;\n\tvec2 circleCoords = 2.0 * (vec2(vUv) - 0.5);\n\n    // Disolve\n    float noise2 = snoise(vec3(vUv.x * (ratio) * 12.0, vUv.y * 12.0, time)) + 1.0;\n    float noise3 = snoise(vec3(vUv.x * (ratio) * 6.0 + (noise2 * 0.2), vUv.y * 6.0 + (noise2 * 0.2), time)) + 1.0;\n\tfloat circleEdge = circle(circleCoords, 2.8 * uTransition, uTransition + max(noise3, 0.5), clamp(smoothstep(0., 0.3, noise2), 0., 0.3));\n\tcircleEdge += circle(circleCoords, 3.3 * uTransition, uTransition + max(noise3, 0.1), 0.3) * 0.5;\n\n\tvec4 colorA;\n\tvec4 colorB;\n\n\tif (uLoaderTransition) {\n\t\tcolorA = vec4(uBgColor, 1.);\n\t\tcolorB = sketchColor;\n\t} else {\n\t\tcolorA = sketchColor;\n\t\tcolorB = sceneColor;\n\t}\n\t\n\n    gl_FragColor = mix(colorA, colorB, min(circleEdge * smoothstep(0.05, 0.3, uTransition), 1.0));\n}",vertexShader:"#define GLSLIFY 1\nvarying vec2 vUv;\n\nvoid main () {\n\n    vUv = uv;\n    gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1 );\n\n}"})),this.sketchPass.enabled=!1,this.fxaaPass=new Pu(Hu),this.fxaaPass.material.uniforms.resolution.value.set(1/(i().window.w*this.renderer.getPixelRatio()),1/(i().window.h*this.renderer.getPixelRatio())),this.composerPasses.add(this.renderPass,0),this.composerPasses.add(this.fxaaPass,100),this.composerPasses.add(this.sketchPass,101)}addEvents(){M.on(E.RESIZE,this.onResize),"dom"!==i().startLocation&&this.enableRaf(),M.on("FPSChecked",this.onFPSChec